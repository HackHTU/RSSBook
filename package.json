{
	"catalog": {
		"@biomejs/biome": "2.5.2",
		"@elysiajs/eden": "^1.4.9",
		"@elysiajs/html": "^1.4.2",
		"@elysiajs/node": "^1.4.5",
		"@elysiajs/openapi": "^1.4.15",
		"@elysiajs/server-timing": "^1.4.1",
		"@elysiajs/static": "^1.4.10",
		"@kitajs/html": "^4.2.13",
		"@kitajs/ts-html-plugin": "^4.1.4",
		"@rowanmanning/feed-parser": "^2.1.3",
		"@types/bun": "latest",
		"@types/sanitize-html": "^2.16.1",
		"bun-types": "latest",
		"cheerio": "^1.2.0",
		"dayjs": "^1.11.21",
		"elysia": "^1.4.29",
		"feed": "^5.2.1",
		"netlify-cli": "latest",
		"ofetch": "^1.5.1",
		"sanitize-html": "^2.17.5",
		"tsx": "latest",
		"unstorage": "1.17.5",
		"uuid": "^13.0.2",
		"vercel": "latest",
		"wrangler": "latest"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@kitajs/ts-html-plugin": "catalog:",
		"@types/bun": "catalog:",
		"@types/sanitize-html": "catalog:"
	},
	"name": "rssbook-monorepo",
	"packageManager": "bun@1.3.2",
	"private": true,
	"scripts": {
		"build": "bun run --cwd pkgs/rssbook build",
		"check": "bun run check:type && bun run check:biome",
		"check:biome": "bunx biome check .",
		"check:type": "bun run check:type:root && bun run check:type:packages",
		"check:type:packages": "bunx tsc -p pkgs/rssbook/tsconfig.json --noEmit && bunx tsc -p pkgs/utils-feed-helper/tsconfig.json --noEmit && bunx tsc -p platform/cloudflare/tsconfig.json --noEmit && bunx tsc -p platform/deno/tsconfig.json --noEmit && bunx tsc -p platform/netlify/tsconfig.json --noEmit && bunx tsc -p platform/node/tsconfig.json --noEmit && bunx tsc -p platform/vercel/tsconfig.json --noEmit",
		"check:type:root": "bunx tsc --noEmit",
		"dev": "bun run --cwd pkgs/rssbook dev",
		"source:new": "bun run scripts/add.source.ts",
		"source:test": "bun run scripts/test.source.ts",
		"source:test:all": "bun test ./pkgs/rssbook/src/routers",
		"start": "bun run --cwd pkgs/rssbook start",
		"test": "xss-scan && bun test ./pkgs/rssbook/src/tests",
		"test:cov": "bun test --coverage ./pkgs/rssbook/src/tests"
	},
	"workspaces": [
		"pkgs/*",
		"platform/*"
	]
}

{
	"bugs": {
		"url": "https://github.com/HackHTU/RSSBook/issues"
	},
	"dependencies": {
		"@elysiajs/eden": "^1.4.9",
		"@elysiajs/html": "^1.4.0",
		"@elysiajs/node": "^1.4.5",
		"@elysiajs/openapi": "^1.4.14",
		"@elysiajs/server-timing": "^1.4.0",
		"@elysiajs/static": "^1.4.9",
		"@rowanmanning/feed-parser": "^2.1.3",
		"cheerio": "^1.2.0",
		"dayjs": "^1.11.20",
		"elysia": "^1.4.28",
		"feed": "^5.2.0",
		"ofetch": "^1.5.1",
		"sanitize-html": "^2.17.2",
		"unstorage": "1.17.5",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.4",
		"@types/sanitize-html": "^2.16.1",
		"bun-types": "1.3.12"
	},
	"homepage": "https://github.com/HackHTU/RSSBook",
	"license": "MIT",
	"main": "src/index.ts",
	"name": "rssbook",
	"packageManager": "bun@1.3.2",
	"scripts": {
		"build": "bun build --define process.env.NODE_ENV='\"production\"' --minify-whitespace --minify-syntax --outfile ./dist/index.js --target bun src/index.ts",
		"build:deno": "",
		"build:node": "bun build --define process.env.NODE_ENV='\"production\"' --minify-whitespace --minify-syntax --outfile ./dist/index.js --target node src/node.ts",
		"build:vercel": "bun build --define process.env.NODE_ENV='\"production\"' --minify-whitespace --minify-syntax --outfile ./dist/index.js --target node src/node.ts",
		"check": "bun run check:ts && bun run check:biome",
		"check:biome": "bunx biome check --write",
		"check:ts": "bunx tsc --noEmit",
		"deploy:vercel": "bunx vercel --prod",
		"dev": "bun --watch run src/index.ts",
		"dev:cf": "bunx wrangler dev",
		"dev:deno": "deno run --watch src/deno.ts",
		"dev:netlify": "bunx netlify dev",
		"dev:node": "npx tsx src/node.ts",
		"dev:vercel": "bunx vercel dev",
		"source:new": "bun run scripts/add.source.ts",
		"source:test": "bun run scripts/test.source.ts",
		"source:test:all": "bun test ./src/routers",
		"test": "xss-scan && bun test ./src/tests",
		"test:cov": "bun test --coverage ./src/tests"
	},
	"type": "module",
	"version": "0.0.1"
}

{
	"bugs": {
		"url": "https://github.com/HackHTU/RSSBook/issues"
	},
	"dependencies": {
		"@elysiajs/eden": "catalog:",
		"@elysiajs/html": "catalog:",
		"@elysiajs/openapi": "catalog:",
		"@elysiajs/server-timing": "catalog:",
		"@elysiajs/static": "catalog:",
		"@kitajs/html": "catalog:",
		"@kitajs/ts-html-plugin": "catalog:",
		"@rowanmanning/feed-parser": "catalog:",
		"cheerio": "catalog:",
		"dayjs": "catalog:",
		"elysia": "catalog:",
		"feed": "catalog:",
		"ofetch": "catalog:",
		"sanitize-html": "catalog:",
		"unstorage": "catalog:",
		"uuid": "catalog:"
	},
	"exports": {
		".": "./src/RSSBookApp.ts",
		"./bun": "./src/index.ts",
		"./utils": "./src/utils/index.ts"
	},
	"homepage": "https://github.com/HackHTU/RSSBook",
	"license": "MIT",
	"main": "src/RSSBookApp.ts",
	"name": "rssbook",
	"repository": {
		"type": "git",
		"url": "git://github.com/HackHTU/RSSBook.git"
	},
	"scripts": {
		"build": "bun build --define process.env.NODE_ENV='\"production\"' --minify-whitespace --minify-syntax --outfile ../../dist/bun/index.js --target bun src/index.ts",
		"dev": "bun --watch src/index.ts",
		"start": "bun ../../dist/bun/index.js",
		"version:major": "npm version major",
		"version:minor": "npm version minor",
		"version:patch": "npm version patch"
	},
	"type": "module",
	"version": "0.0.1"
}

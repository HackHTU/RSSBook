{
	"bugs": {
		"url": "https://github.com/HackHTU/RSSBook/issues"
	},
	"dependencies": {
		"@elysiajs/eden": "catalog:",
		"@elysiajs/html": "catalog:",
		"@elysiajs/openapi": "catalog:",
		"@elysiajs/server-timing": "catalog:",
		"@elysiajs/static": "catalog:",
		"@kitajs/html": "catalog:",
		"@kitajs/ts-html-plugin": "catalog:",
		"@rowanmanning/feed-parser": "catalog:",
		"cheerio": "catalog:",
		"dayjs": "catalog:",
		"domhandler": "catalog:",
		"elysia": "catalog:",
		"feed": "catalog:",
		"ofetch": "catalog:",
		"sanitize-html": "catalog:",
		"unstorage": "catalog:",
		"uuid": "catalog:"
	},
	"devDependencies": {
		"tsup": "catalog:"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"homepage": "https://github.com/HackHTU/RSSBook",
	"license": "MIT",
	"name": "rssbook",
	"repository": {
		"type": "git",
		"url": "git://github.com/HackHTU/RSSBook.git"
	},
	"scripts": {
		"build": "rm -rf dist && bun build src/index.ts --target=bun --format=esm --packages=external --sourcemap=linked --outdir=dist && bunx tsup && mkdir -p dist/public/xsl && cp src/public/favicon.ico src/public/favicon.svg src/public/robots.txt dist/public/ && cp src/public/xsl/atom.xsl src/public/xsl/rss.xsl dist/public/xsl/",
		"check": "tsc --noEmit",
		"dev": "bun --watch src/index.ts",
		"version:major": "npm version major",
		"version:minor": "npm version minor",
		"version:patch": "npm version patch"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"version": "0.0.1"
}

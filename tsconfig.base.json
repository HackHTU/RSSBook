{
	"compilerOptions": {
		"alwaysStrict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"jsx": "react-jsx",
		"jsxImportSource": "@kitajs/html",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noErrorTruncation": true,
		"noImplicitAny": true,
		"plugins": [
			{
				"name": "@kitajs/ts-html-plugin"
			}
		],
		"skipLibCheck": true,
		"strict": true,
		"strictNullChecks": true,
		"target": "ESNext"
	}
}
